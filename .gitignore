# ─── OS / editor junk ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# ─── Logs ─────────────────────────────────────────────────────
*.log
error_log
debug.log

# ─── Secrets (config files with hardcoded credentials) ────────
# IMPORTANT: keep these out of git. Commit a `*.example.php`
# template instead if you want others to know the shape.
db.php
Panel/db.php
payment/config.php
payment2/config.php
.env
.env.*

# ─── Heavy user-uploaded / generated content ──────────────────
# CV uploads contain real applicant PII — never push these.
uploads/
Panel/uploads/

# WordPress media library + cache (1.3 GB; over GitHub's reasonable size)
wp-content/uploads/
wp-content/cache/

# Generated PDF/image temp dir (~4700 files, mostly phase2_*.png)
temp/

# ─── Redundant archives (libs are already extracted) ──────────
# PHPMailer/, tcpdf/, phpqrcode/ are in source form — the
# original .zip files in Panel/ are dead weight.
*.zip

# ─── DB dumps / backups ───────────────────────────────────────
*.sql
*.sql.gz
*.dump
*.bak
*.orig
