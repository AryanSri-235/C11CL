<script>
    let myEditor;

    // 1. CKEditor Initialization
    ClassicEditor
        .create(document.querySelector('#editor'), {
            toolbar: [ 'heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'undo', 'redo' ]
        })
        .then(editor => { myEditor = editor; })
        .catch(err => { console.error(err); });

    // 2. Slug Auto Gen
    document.getElementById('blog_title').addEventListener('input', function() {
        let slug = this.value.toLowerCase().replace(/[^\w ]+/g, '').replace(/ +/g, '-');
        document.getElementById('blog_slug').value = slug;
    });

    // 3. Form Submit Progress
    document.getElementById('blogForm').addEventListener('submit', function(e) {
        if(myEditor.getData().trim() === '') {
            Swal.fire('Wait!', 'Content is empty.', 'warning');
            e.preventDefault();
            return false;
        }
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('btnText').innerText = "Uploading to Server...";
        document.getElementById('btnSpinner').style.display = "inline-block";
    });

    // 4. Success Alert with Preview
    <?php if($success_flag): ?>
        Swal.fire({
            title: 'Successfully Published! ✨',
            html: 'Your blog is now live on the website.',
            icon: 'success',
            showCancelButton: true,
            confirmButtonText: 'Preview Post 👁️',
            cancelButtonText: 'Back to List',
            confirmButtonColor: '#28a745'
        }).then((result) => {
            if (result.isConfirmed) {
                window.open('../blog-details.php?id=<?php echo $new_id; ?>', '_blank');
            }
            window.location.href='blog.php';
        });
    <?php endif; ?>

    <?php if(!empty($error_msg)): ?>
        Swal.fire('Execution Error', '<?php echo addslashes($error_msg); ?>', 'error');
        document.getElementById('submitBtn').disabled = false;
        document.getElementById('btnText').innerText = "🚀 Publish Blog Now";
    <?php endif; ?>
</script>

