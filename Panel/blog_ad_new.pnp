<?php
session_start();
error_reporting(E_ALL);
ini_set('display_errors', 1);

if (!isset($_SESSION['password'])) {
    header('location:login.php');
    exit();
}

include 'db.php'; 

$success_flag = false;
$new_id = 0;
$error_msg = '';

if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['publish_post'])) {
    
    $created_by = $_SESSION['name'] ?? 'Admin'; 
    $created_at = date('Y-m-d H:i:s');

    // Data Collection
    $title = $_POST['title'];
    $slug = $_POST['slug'];
    $short_desc = $_POST['short_desc'];
    $content = $_POST['content']; 
    $category = $_POST['category'];
    $tags = $_POST['tags'];
    $author = $_POST['author_name'];
    
    $meta_title = $_POST['meta_title'];
    $meta_desc = $_POST['meta_desc'];
    $focus_keyword = $_POST['focus_keyword'];
    $canonical_url = $_POST['canonical_url'];
    $robots = $_POST['robots'];
    $schema_markup = $_POST['schema_markup'];

    $og_title = $_POST['og_title'];
    $og_desc = $_POST['og_desc'];

    $status = $_POST['status'];
    $publish_date = !empty($_POST['publish_date']) ? $_POST['publish_date'] : $created_at;
    $allow_comments = isset($_POST['allow_comments']) ? 1 : 0;
    $is_featured = isset($_POST['is_featured']) ? 1 : 0;

    function uploadFile($fileKey) {
        if (!empty($_FILES[$fileKey]['name'])) {
            $folder = 'uploads/';
            if (!is_dir($folder)) mkdir($folder, 0777, true);
            $path = $folder . time() . '_' . basename($_FILES[$fileKey]['name']);
            move_uploaded_file($_FILES[$fileKey]['tmp_name'], $path);
            return $path;
        }
        return '';
    }

    $featured_img = uploadFile('featured_img');
    $og_img = uploadFile('og_img');

    // Database Insert (23 Columns)
    $sql = "INSERT INTO blog (title, slug, short_desc, content, category, tags, author, created_by, created_at, meta_title, meta_desc, focus_keyword, canonical_url, robots, schema_markup, og_title, og_desc, featured_img, og_img, status, publish_date, allow_comments, is_featured) 
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)";
    
    $stmt = $con->prepare($sql);
    $stmt->bind_param("sssssssssssssssssssssss", 
        $title, $slug, $short_desc, $content, $category, $tags, $author, $created_by, $created_at, 
        $meta_title, $meta_desc, $focus_keyword, $canonical_url, $robots, $schema_markup,
        $og_title, $og_desc, $featured_img, $og_img, $status, $publish_date, $allow_comments, $is_featured
    );

    if ($stmt->execute()) {
        $success_flag = true;
        $new_id = $con->insert_id;
    } else {
        $error_msg = $stmt->error;
    }
}
include 'head.php';
?>

